{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "go (non-major)",
      "groupSlug": "go-non-major",
      "addLabels": [
        "autoreview"
      ],
      "automerge": true
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "autoreview"
      ],
      "automerge": false
    }
  ]
}
