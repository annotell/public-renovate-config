{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": [
        "gradle",
        "gradle-wrapper"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "gradle (non-major)",
      "groupSlug": "gradle-non-major",
      "addLabels": [
        "autoreview"
      ],
      "automerge": false
    },
    {
      "matchManagers": [
        "gradle",
        "gradle-wrapper"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "autoreview"
      ],
      "automerge": false
    },
    {
      "description": "Scala version bumps must be human-triggered. Renovate keeps closing these PRs and bumping the Scala stdlib has cross-cutting compiler/library implications that need a coordinated upgrade.",
      "matchManagers": [
        "gradle"
      ],
      "matchPackageNames": [
        "org.scala-lang:scala-library"
      ],
      "enabled": false
    }
  ]
}