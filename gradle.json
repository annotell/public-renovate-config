{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": [
        "gradle",
        "gradle-wrapper"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "gradle (non-major)",
      "groupSlug": "gradle-non-major",
      "addLabels": [
        "autoreview"
      ],
      "automerge": false
    },
    {
      "matchManagers": [
        "gradle",
        "gradle-wrapper"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "autoreview"
      ],
      "automerge": false
    }
  ]
}