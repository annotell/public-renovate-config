{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // Goal: language deps only land during business hours so the
  // image-updater-driven prod deploys happen while people are around.
  // GHA is low-risk and can land any time.
  packageRules: [
    {
      matchManagers: [
        "pip_requirements",
        "poetry",
        "pep621",
        "pip_setup",
        "npm",
        "pnpm",
        "gomod",
        "gradle",
        "cargo",
        "dockerfile",
        "docker-compose",
        "helmv3",
        "helm-values",
        "kustomize",
      ],
      schedule: ["after 08:00 and before 16:00 every weekday"],
    },
    {
      matchManagers: ["github-actions"],
      schedule: ["every weekday"],
    },
  ],
}
