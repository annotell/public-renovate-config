{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "annotell/*"
      ],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchManagers": [
        "pip_requirements",
        "pip_setup",
        "pep621",
        "poetry",
        "pipenv",
        "pip-compile"
      ],
      "matchPackageNames": [
        "/^kognic-/"
      ],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchManagers": [
        "gradle",
        "gradle-wrapper"
      ],
      "matchPackageNames": [
        "/^com\\.kognic\\./"
      ],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchManagers": [
        "npm",
        "bun"
      ],
      "matchPackageNames": [
        "/^@kognic\\//",
        "/^@annotell\\//"
      ],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchManagers": [
        "cargo"
      ],
      "matchPackageNames": [
        "/github\\.com\\/(annotell|kognic)\\//"
      ],
      "minimumReleaseAge": "0 days"
    }
  ]
}